NODE_ENV=development
ISSUER_SERVICE_PORT=4001
VERIFIER_SERVICE_PORT=4002
DID_RESOLVER_PORT=4003
REVOCATION_SERVICE_PORT=4004

ISSUER_ID=did:key:z6Mkexample
ISSUER_BASE_URL=http://issuer-service:4001
TRUSTED_DID_WEB_DOMAINS=example.com

# Multibase private key for Ed25519VerificationKey2020
ISSUER_PRIVATE_KEY_MULTIBASE=zExamplePrivateKeyMultibase
ISSUER_PUBLIC_KEY_MULTIBASE=zExamplePublicKeyMultibase

DID_WEB_FALLBACK_DIR=/app/did-web
STATUS_LIST_BASE_URL=http://issuer-service:4001/v1/status-lists
OID4VC_ISSUER_URL=http://issuer-service:4001
OID4VP_VERIFIER_URL=http://verifier-service:4002
