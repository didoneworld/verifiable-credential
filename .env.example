NODE_ENV=development

ISSUER_SERVICE_PORT=4001
VERIFIER_SERVICE_PORT=4002
DID_RESOLVER_PORT=4003
REVOCATION_SERVICE_PORT=4004

ISSUER_ID=did:example:issuer
ISSUER_BASE_URL=http://issuer-service:4001

# Base64-encoded 32-byte Ed25519 seed/private key
ISSUER_PRIVATE_KEY_BASE64=replace_with_base64_private_key
# Base64-encoded 32-byte Ed25519 public key
ISSUER_PUBLIC_KEY_BASE64=replace_with_base64_public_key

# JSON object string map, e.g. {"did:example:issuer":"<base64_public_key>"}
DID_PUBLIC_KEY_MAP={}

REVOCATION_MODE=internal
